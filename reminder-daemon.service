[Unit]
Description=Benten Schedule Reminder Daemon
After=network.target

[Service]
Type=simple
User=connoise
WorkingDirectory=/home/connoise/Schedule
ExecStart=/usr/bin/python3 /home/connoise/Schedule/reminder_daemon.py
Restart=always
RestartSec=10
Environment=TELEGRAM_BOT_TOKEN=<your_bot_token>
Environment=TELEGRAM_CHAT_ID=<your_chat_id>
Environment=REMINDERS_FILE=/home/connoise/Schedule/reminders.json

[Install]
WantedBy=multi-user.target
